{
    "cli": {
        "version": ">= 13.2.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
                "NPM_FLAGS": "--legacy-peer-deps"
            },
            "node": "20.18.1"
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            },
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
            }
        }
    },
    "submit": {
        "production": {}
    }
}